# Root docker-compose secrets. Copy to .env and fill in:
#   cp .env.example .env

# Shared Laravel app key (all services). Generate one:
#   docker compose run --rm auth-service php artisan key:generate --show
# or with a local PHP:  cd services/auth-service && php artisan key:generate --show
APP_KEY=

# JWT signing secret for auth-service. Generate:
#   docker compose run --rm auth-service php artisan jwt:secret --show
JWT_SECRET=

# MySQL root password (used by every service for its own schema in this dev stack).
MYSQL_ROOT_PASSWORD=changeme

# Browser-reachable gateway origin baked into the SPA at build time.
VITE_API_GATEWAY_URL=http://localhost:8080
